generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  role              String?
  accounts          Account[]
  classroomsCreated Classroom[]        @relation("TeacherClassrooms")
  enrollments       Enrollment[]
  PracticeErrorLog  PracticeErrorLog[]
  sessions          Session[]
  submissions       Submission[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Classroom {
  id          String       @id @default(cuid())
  name        String
  inviteCode  String       @unique
  createdAt   DateTime     @default(now())
  teacherId   String
  group       String?
  isArchived  Boolean      @default(false)
  teacher     User         @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  practices   Practice[]

  @@index([isArchived])
  @@index([teacherId])
}

model Enrollment {
  id          String    @id @default(cuid())
  joinedAt    DateTime  @default(now())
  userId      String
  classroomId String
  isArchived  Boolean   @default(false)
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, classroomId])
  @@index([classroomId])
  @@index([userId])
}

model Practice {
  id                   String             @id @default(cuid())
  title                String
  description          String?
  requiredFunctions    Json?
  totalPoints          Int                @default(100)
  createdAt            DateTime           @default(now())
  deadline             DateTime?
  classroomId          String
  closeLateSubmissions Boolean            @default(false)
  checklistItems       ChecklistItem[]
  classroom            Classroom          @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  PracticeErrorLog     PracticeErrorLog[]
  submissions          Submission[]

  @@index([classroomId])
}

model ChecklistItem {
  id          String                @id @default(cuid())
  criterion   String
  maxPoints   Int
  practiceId  String
  evaluations ChecklistEvaluation[]
  practice    Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
}

model Submission {
  id                 String                @id @default(cuid())
  studentSqlCode     String?
  generatedStatement String?
  reviewStatus       String                @default("en_progreso")
  submittedAt        DateTime              @default(now())
  userId             String
  practiceId         String
  setupSql           String?
  executionResult    String?
  evaluations        ChecklistEvaluation[]
  practice           Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, practiceId])
  @@index([practiceId])
  @@index([userId])
}

model ChecklistEvaluation {
  id              String        @id @default(cuid())
  aiComplies      Boolean?
  teacherComplies Boolean?
  submissionId    String
  checklistItemId String
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  submission      Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, checklistItemId])
}

model PracticeErrorLog {
  id              String   @id
  errorCategory   String
  sqlConcept      String
  originalMessage String?
  createdAt       DateTime @default(now())
  userId          String
  practiceId      String
  Practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([userId])
}
